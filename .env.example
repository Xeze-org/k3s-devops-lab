# ============================================================================
#  k3s DevOps Lab — configuration
#  Copy this file to ".env" and fill in the values.  ".env" is gitignored.
#
#  Two kinds of values live here:
#    - SECRETS  -> injected into the cluster as k8s Secrets by Ansible.
#                 They NEVER get committed to Git.
#    - FLAGS    -> rendered into gitops/root/values.yaml (committed & pushed),
#                 because ArgoCD needs to read them from Git.
# ============================================================================

# ── Domain (FLAG: written to values.yaml; used for *.DOMAIN ingress hosts) ──
DOMAIN=mydomain.org

# ── Cloudflare (SECRET: injected to cluster, used by Ansible to call CF API) ──
# API token scope required: Zone:DNS:Edit  +  Account:Cloudflare Tunnel:Edit
CF_API_TOKEN=
CF_ACCOUNT_ID=

# ── GitOps source (SECRET token; repo URL is non-sensitive) ──
GIT_REPO=https://github.com/Xeze-org/k3s-devops-lab.git
GIT_BRANCH=main
GITHUB_TOKEN=

# ── Tool flags (FLAG: true/false; rendered into values.yaml) ──
MONITORING=true       # kube-prometheus-stack (Prometheus + Grafana)
LOKI=true             # Loki log aggregation (shows up in Grafana)
JENKINS=false         # Jenkins CI (JVM, heavy: +2GB)
NEXUS=false           # Nexus artifact repo (JVM, heavy: +2GB)

# ── VM sizing override (optional) ──
# Leave BLANK to auto-compute from the flags above.
# Set a value to force it (still clamped to 4096-8192 MB / 2-4 CPU).
VM_MEMORY=
VM_CPUS=
